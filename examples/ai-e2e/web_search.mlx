let s = React.string

let container_style =
  ReactDOM.Style.make ~display:"flex" ~flexDirection:"column" ~height:"100vh" ~padding:"24px" ~maxWidth:"768px"
    ~margin:"0 auto" ~width:"100%" ()

let header_style = ReactDOM.Style.make ~marginBottom:"16px" ~paddingBottom:"16px" ~borderBottom:"1px solid #e5e7eb" ()

let title_style = ReactDOM.Style.make ~fontSize:"18px" ~fontWeight:"700" ~color:"#111827" ()

let description_style = ReactDOM.Style.make ~fontSize:"13px" ~color:"#6b7280" ~marginTop:"4px" ()

let banner_style =
  ReactDOM.Style.make ~padding:"16px" ~borderRadius:"8px" ~background:"#fffbeb" ~border:"1px solid #fde68a"
    ~marginTop:"16px" ()

let banner_title_style = ReactDOM.Style.make ~fontWeight:"600" ~fontSize:"14px" ~color:"#92400e" ~marginBottom:"8px" ()

let banner_text_style = ReactDOM.Style.make ~fontSize:"13px" ~color:"#78350f" ~lineHeight:"1.5" ()

let code_style =
  ReactDOM.Style.make ~marginTop:"16px" ~padding:"16px" ~borderRadius:"8px" ~background:"#f9fafb"
    ~border:"1px solid #e5e7eb" ~fontFamily:"ui-monospace, monospace" ~fontSize:"12px" ~color:"#374151"
    ~whiteSpace:"pre-wrap" ~overflowX:"auto" ()
  (* Web search demo: provider-specific built-in search tools.
   Needs:
   - Anthropic: webSearch_20250305 / webSearch_20260209 tool passthrough
   - OpenAI: webSearch built-in tool
   - Server-side: ability to pass provider-specific tools to stream_text
   - Source URL parts are already supported in the message renderer *)
  [@react.component]
let make () =
  <div style=container_style>
    <div style=header_style>
      <div style=title_style>(s "Web Search")</div>
      <div style=description_style>(s "Provider built-in web search tools.")</div>
    </div>
    <div style=banner_style>
      <div style=banner_title_style>(s "Coming Soon")</div>
      <div style=banner_text_style>
        (s "This demo requires provider-specific tool passthrough support. ")
        (s "Source URL rendering is already implemented in the message component.")
      </div>
    </div>
    <div style=code_style>
      (s
         {|(* Planned implementation:

(* Anthropic web search tool *)
let anthropic_web_search =
  Ai_provider_anthropic.web_search_tool
    ~name:"webSearch_20250305" ()

(* The message renderer already handles Source_url parts:
   sources appear as clickable links below the response. *)

<Chat_layout
  title="Web Search"
  description="Provider built-in web search."
  endpoint="/api/chat/web-search"
/> *)|})
    </div>
  </div>
