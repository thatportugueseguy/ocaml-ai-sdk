  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "ai": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
