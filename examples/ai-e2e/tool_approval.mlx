let _mlx = () [@react.component]
let make () =
  Chat_layout.render ~title:"Tool Approval"
    ~description:"Human-in-the-loop approval. Weather needs approval, search executes immediately."
    ~endpoint:"/api/chat/approval"
    ~send_automatically_when:Ai_sdk_react.Use_chat.last_assistant_message_is_complete_with_approval_responses ()
