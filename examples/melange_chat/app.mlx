open Ai_sdk_react

external protocol : string = "protocol" [@@mel.scope "window", "location"]
external hostname : string = "hostname" [@@mel.scope "window", "location"]

let api_url = protocol ^ "//" ^ hostname ^ ":28601/chat"
let s = React.string

(** Try to parse structured JSON response with {summary, data:[{label,value}]} *)
let try_parse_structured text =
  try
    let json = Js.Json.parseExn text in
    match Js.Json.decodeObject json with
    | Some obj ->
      let summary =
        match Js.Dict.get obj "summary" with
        | Some v -> Js.Json.decodeString v
        | None -> None
      in
      let data =
        match Js.Dict.get obj "data" with
        | Some v -> Js.Json.decodeArray v
        | None -> None
      in
      (match summary, data with
      | Some s, Some d -> Some (s, d)
      | _ -> None)
    | None -> None
  with _ -> None

let render_data_point j item =
  let key = string_of_int j in
  match Js.Json.decodeObject item with
  | Some obj ->
    let label =
      match Js.Dict.get obj "label" with
      | Some v -> Option.value ~default:"" (Js.Json.decodeString v)
      | None -> ""
    in
    let value =
      match Js.Dict.get obj "value" with
      | Some v -> Option.value ~default:"" (Js.Json.decodeString v)
      | None -> ""
    in
    let border_bottom =
      (* no border for last item — caller doesn't know total, so always show *)
      "1px solid #e9ecef"
    in
    <div
      key
      style=(ReactDOM.Style.make ~display:"flex" ~justifyContent:"space-between" ~padding:"4px 0"
               ~borderBottom:border_bottom ())>
      <span style=(ReactDOM.Style.make ~color:"#666" ~fontWeight:"500" ())>(s label)</span> <span>(s value)</span>
    </div>
  | None -> React.null

let render_structured_response key summary data =
  let data_items = data |> Array.to_list |> List.mapi render_data_point |> Array.of_list |> React.array in
  <div key style=(ReactDOM.Style.make ~marginTop:"8px" ())>
    <p style=(ReactDOM.Style.make ~marginBottom:"8px" ())>(s summary)</p>
    <div
      style=(ReactDOM.Style.make ~background:"#f8f9fa" ~borderRadius:"6px" ~padding:"12px" ~border:"1px solid #e9ecef"
               ())>
      data_items
    </div>
  </div>

let render_part chat i part =
  let key = string_of_int i in
  match classify part with
  | Text p ->
    let text = text_ui_part_text p in
    (match try_parse_structured text with
    | Some (summary, data) -> render_structured_response key summary data
    | None -> <span key>(s text)</span>)
  | Tool_call p ->
    let state = tool_ui_part_state p in
    let is_approval_requested = String.equal state "approval-requested" in
    let is_result = String.equal state "output-available" in
    let is_error = String.equal state "output-error" in
    let name_str =
      match tool_ui_part_tool_name p with
      | Some n -> n
      | None ->
        let pt = part_type part in
        if String.length pt > 5 then String.sub pt 5 (String.length pt - 5) else pt
    in
    let tool_name = s name_str in
    let state_label = s (" (" ^ state ^ ")") in
    let input_display =
      match tool_ui_part_input p with
      | Some json ->
        let json_str = s (Js.Json.stringify json) in
        <div style=(ReactDOM.Style.make ~marginTop:"4px" ~color:"#555" ())>json_str</div>
      | None -> React.null
    in
    let approval_buttons =
      if is_approval_requested then (
        match tool_ui_part_approval p with
        | Some approval ->
          let approval_id = tool_approval_id approval in
          let on_approve _ =
            Use_chat.add_tool_approval_response chat
              (Use_chat.make_tool_approval_response ~id:approval_id ~approved:true ())
          in
          let on_deny _ =
            Use_chat.add_tool_approval_response chat
              (Use_chat.make_tool_approval_response ~id:approval_id ~approved:false ())
          in
          <div style=(ReactDOM.Style.make ~marginTop:"8px" ~display:"flex" ~gap:"8px" ())>
            <button
              onClick=on_approve
              style=(ReactDOM.Style.make ~padding:"4px 12px" ~borderRadius:"4px" ~border:"1px solid #2e7d32"
                       ~background:"#e8f5e9" ~color:"#2e7d32" ~cursor:"pointer" ~fontSize:"12px" ~fontWeight:"600" ())>
              (s "Approve")
            </button>
            <button
              onClick=on_deny
              style=(ReactDOM.Style.make ~padding:"4px 12px" ~borderRadius:"4px" ~border:"1px solid #c62828"
                       ~background:"#ffebee" ~color:"#c62828" ~cursor:"pointer" ~fontSize:"12px" ~fontWeight:"600" ())>
              (s "Deny")
            </button>
          </div>
        | None -> React.null)
      else React.null
    in
    let output_display =
      if is_result then (
        match tool_ui_part_output p with
        | Some json ->
          let json_str = s (Js.Json.stringify json) in
          <div style=(ReactDOM.Style.make ~marginTop:"4px" ~color:"#2e7d32" ())>json_str</div>
        | None -> React.null)
      else React.null
    in
    let error_display =
      if is_error then (
        match tool_ui_part_error_text p with
        | Some err ->
          let err_msg = s err in
          <div style=(ReactDOM.Style.make ~marginTop:"4px" ~color:"#c62828" ())>err_msg</div>
        | None -> React.null)
      else React.null
    in
    let bg =
      match () with
      | () when is_approval_requested -> "#fff8e1"
      | () when is_error -> "#fee"
      | () -> "#f5f5f5"
    in
    <div
      key
      style=(ReactDOM.Style.make ~background:bg ~padding:"8px" ~borderRadius:"4px" ~fontSize:"13px" ~marginTop:"4px"
               ~fontFamily:"monospace" ())>
      <div><strong>tool_name</strong> state_label</div> input_display approval_buttons output_display error_display
    </div>
  | Step_start _ -> React.null
  | _ -> React.null

let render_message chat msg =
  let role = ui_message_role msg in
  let is_user =
    match role with
    | User -> true
    | _ -> false
  in
  let bg = if is_user then "#e3f2fd" else "#fff" in
  let label = s (if is_user then "You" else "Claude") in
  let parts = ui_message_parts msg |> Array.to_list |> List.mapi (render_part chat) |> Array.of_list |> React.array in
  (div ()
     ~children:
       [
         <strong>label</strong>; <div style=(ReactDOM.Style.make ~whiteSpace:"pre-wrap" ~marginTop:"4px" ())>parts</div>;
       ]
     ~key:(ui_message_id msg)
     ~style:
       (ReactDOM.Style.make ~marginBottom:"12px" ~padding:"8px" ~borderRadius:"6px" ~background:bg
          ~border:"1px solid #eee" ()) [@JSX] [@react.component])

let make () =
  let input, set_input = React.useState (fun () -> "") in
  let transport = Use_chat.Default_chat_transport.(make ~api:api_url () |> to_transport) in
  let chat =
    Use_chat.use_chat ~transport
      ~send_automatically_when:Use_chat.last_assistant_message_is_complete_with_approval_responses ()
  in
  let messages = Use_chat.messages chat in
  let status = Use_chat.status chat in
  let is_loading =
    match status with
    | Ready -> false
    | Submitted | Streaming | Error -> true
  in
  let on_submit e =
    React.Event.Form.preventDefault e;
    let trimmed = Js.String.trim input in
    if String.length trimmed > 0 then (
      Use_chat.send_text chat trimmed;
      set_input (fun _ -> ""))
  in
  let error_banner =
    match Use_chat.error chat with
    | Some err ->
      let msg =
        match Js.Exn.message err with
        | Some m -> m
        | None -> "Unknown error"
      in
      <div
        style=(ReactDOM.Style.make ~padding:"8px 12px" ~marginBottom:"12px" ~borderRadius:"6px" ~background:"#fee"
                 ~border:"1px solid #fcc" ~color:"#c62828" ~fontSize:"13px" ())>
        <strong>(s "Error: ")</strong> (s msg)
      </div>
    | None -> React.null
  in
  let title = s "OCaml AI SDK Chat (Melange)" in
  let placeholder_msg = s "Send a message to start chatting..." in
  let empty_state =
    if Array.length messages = 0 then <p style=(ReactDOM.Style.make ~color:"#999" ())>placeholder_msg</p>
    else React.null
  in
  let message_list = messages |> Array.to_list |> List.map (render_message chat) |> Array.of_list |> React.array in
  let button_label = if is_loading then s "..." else s "Send" in
  let footer = s "Powered by OCaml AI SDK + Anthropic Claude (Melange frontend)" in
  <div style=(ReactDOM.Style.make ~maxWidth:"640px" ~margin:"40px auto" ~fontFamily:"system-ui" ())>
    <h2>title</h2>
    error_banner
    <div
      style=(ReactDOM.Style.make ~border:"1px solid #ddd" ~borderRadius:"8px" ~padding:"16px" ~minHeight:"300px"
               ~maxHeight:"500px" ~overflowY:"auto" ~marginBottom:"16px" ~background:"#fafafa" ())>
      empty_state message_list
    </div>
    <form onSubmit=on_submit style=(ReactDOM.Style.make ~display:"flex" ~gap:"8px" ())>
      <input
        value=input
        onChange=(fun e ->
                   let v : string = (React.Event.Form.target e)##value in
                   set_input (fun _ -> v))
        placeholder="Type a message..."
        disabled=is_loading
        style=(ReactDOM.Style.make ~flex:"1" ~padding:"8px 12px" ~borderRadius:"6px" ~border:"1px solid #ccc"
                 ~fontSize:"14px" ())
      />
      <button
        type_="submit"
        disabled=(is_loading || String.length (Js.String.trim input) = 0)
        style=(ReactDOM.Style.make ~padding:"8px 20px" ~borderRadius:"6px" ~border:"none"
                 ~background:(if is_loading then "#ccc" else "#1976d2")
                 ~color:"#fff"
                 ~cursor:(if is_loading then "default" else "pointer")
                 ~fontSize:"14px" ())>
        button_label
      </button>
    </form>
    <p style=(ReactDOM.Style.make ~marginTop:"12px" ~fontSize:"12px" ~color:"#999" ())>footer</p>
  </div>
